# =============================================================================
# Parking Lot Management System - Nginx Configuration Template
# =============================================================================

# Port to serve the frontend static files (e.g., 80 for production, 3005 for local/development)
FRONTEND_PORT=80

# Port to reverse-proxy the backend API (e.g., 8080)
BACKEND_PORT=8080

# The hostname or IP address of the backend server.
# Use 127.0.0.1 if both frontend Nginx and backend run on the same remote machine.
# If they are on different machines, set this to the backend server's IP address.
BACKEND_HOST=127.0.0.1
