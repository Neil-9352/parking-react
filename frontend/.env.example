# Base URL for the backend API.
# Point this to the Nginx reverse proxy on the backend machine (port 8080, no path).
# Nginx will forward /api/*, /uploads/*, and /receipts/* to Express automatically.
#
# Examples:
#   LAN:      VITE_API_URL=http://192.168.1.50:8080
#   Domain:   VITE_API_URL=http://parking-api.example.com:8080
#   Local dev (no Nginx, Vite proxy active): VITE_API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
