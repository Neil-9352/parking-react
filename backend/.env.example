# =========================================================================
# Parking Lot Management System - Backend Environment Configuration Template
# =========================================================================

# The environment context (e.g., 'development', 'production', 'test')
# When set to 'production', session cookies default to setting 'secure: true' (requiring HTTPS).
# To override this behavior (e.g. running production mode over HTTP), set COOKIE_SECURE=false.
NODE_ENV=development
COOKIE_SECURE=


# The port number on which the backend server runs
PORT=3001

# -------------------------------------------------------------------------
# Database Configuration
# -------------------------------------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=parking_lot_final
DB_PORT=3306

# -------------------------------------------------------------------------
# JWT (JSON Web Token) Configuration
# -------------------------------------------------------------------------
# Secret key used to sign and verify session tokens (keep this strong in production)
JWT_SECRET=your_jwt_secret_key_here

# Expiration duration for the token (e.g., '8h', '1d')
JWT_EXPIRES_IN=8h

# -------------------------------------------------------------------------
# Cross-Origin Resource Sharing (CORS) & Services Configuration
# -------------------------------------------------------------------------
# URL(s) of the frontend allowed to make direct requests to the backend.
# This is only relevant when running WITHOUT the Nginx reverse proxy
# (e.g., pure local development where Vite proxies /api to this port).
#
# When running BEHIND Nginx (recommended), leave this EMPTY — Nginx handles
# CORS dynamically and Express will permit all origins that reach it via the
# proxy (which is always 127.0.0.1).
#
# To allow specific origins in direct-dev mode, use a comma-separated list:
#   FRONTEND_URL=http://localhost:5173,http://192.168.1.10:5173
FRONTEND_URL=

# URL of the ANPR (Automatic Number Plate Recognition) detection service
ANPR_URL=https://localhost:8000/api/detect
